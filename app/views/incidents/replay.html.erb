<div class="replay-container">
  <div class="replay-section">
    <div class="card">
      <h2 class="text-primary">Incident Transcript Replay</h2>
      
      <div class="button-group">
        <button id="start-replay" class="btn" onclick="startReplay()">Start Replay</button>
        <button id="stop-replay" class="btn btn-secondary" onclick="stopReplay()" style="display: none;">Stop Replay</button>
        <button id="reset-replay" class="btn btn-secondary" onclick="resetReplay()" style="display: none;">Reset</button>
        <button class="btn btn-secondary" onclick="exportAcceptedSuggestions()">Export Accepted</button>
      </div>
      
      <div class="controls">
        <div class="form-group">
          <label for="confidence-filter" class="form-label">Min Confidence:</label>
          <select id="confidence-filter" class="form-control" onchange="filterSuggestions()">
            <option value="0">All (0%+)</option>
            <option value="0.5">Low (50%+)</option>
            <option value="0.7" selected>Medium (70%+)</option>
            <option value="0.8">High (80%+)</option>
            <option value="0.9">Very High (90%+)</option>
          </select>
        </div>
      </div>
      
      <div id="messages" class="messages-container"></div>
    </div>
  </div>
  
  <div class="replay-section">
    <div class="card">
      <h2 class="text-primary">AI Suggestions <span id="queue-status" class="status-indicator text-muted"></span></h2>
      
      <div id="suggestions" class="suggestions-container">
        <p class="text-muted">Suggestions will appear here during replay.</p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Replay specific styles using solid colors */
  .replay-container {
    display: flex;
    gap: 2rem;
    padding: 0;
    margin: 0;
    align-items: flex-start;
  }
  
  .replay-section {
    flex: 1;
    min-width: 0;
  }
  
  .replay-section .card {
    margin-bottom: 0;
    height: calc(100vh - 160px);
    display: flex;
    flex-direction: column;
  }
  
  .replay-section .card h2 {
    margin: 0 0 1rem 0;
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  
  .button-group {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  
  .controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  
  .controls .form-group {
    margin-bottom: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .controls .form-control {
    width: auto;
    min-width: 140px;
  }
  
  .stats-text {
    font-size: 0.8rem;
    white-space: nowrap;
  }
  
  .messages-container {
    flex: 1;
    overflow-y: auto;
    border: 1px solid var(--color-surface-variant);
    border-radius: 8px;
    padding: 1rem;
    background-color: var(--color-surface);
    font-family: 'Monaco', 'Menlo', 'Consolas', monospace;
    line-height: 1.6;
    font-size: 0.9rem;
  }
  
  .suggestions-container {
    flex: 1;
    overflow-y: auto;
    border: 1px solid var(--color-surface-variant);
    border-radius: 8px;
    padding: 1rem;
    background-color: var(--color-surface);
  }
  
  .status-indicator {
    font-size: 0.8rem;
    font-weight: normal;
  }
  
  .message-item {
    margin-bottom: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    background-color: var(--color-surface-variant);
    border-left: 3px solid var(--color-accent);
  }
  
  .message-speaker {
    font-weight: 600;
    color: var(--color-accent);
    margin-right: 0.5rem;
  }
  
  .suggestion-card {
    border: 1px solid var(--color-surface-variant);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1rem;
    background-color: var(--color-surface-variant);
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .suggestion-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  
  .suggestion-card.accepted {
    border-color: var(--color-success);
    background-color: var(--color-surface);
  }
  
  .suggestion-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  
  .suggestion-type {
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }
  
  .suggestion-type.action-item {
    background-color: var(--color-info);
  }
  
  .suggestion-type.trigger-event {
    background-color: var(--color-success);
  }
  
  .suggestion-type.root-cause {
    background-color: var(--color-warning);
  }
  
  .suggestion-type.missing-metadata {
    background-color: var(--color-text-muted);
  }
  
  .suggestion-content {
    margin: 0.75rem 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-text-primary);
  }
  
  .suggestion-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.75rem;
  }
  
  .suggestion-buttons {
    display: flex;
    gap: 0.5rem;
  }
  
  .suggestion-buttons .btn {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }
  
  .suggestion-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  
  .context-panel {
    background-color: var(--color-surface);
    border: 1px solid var(--color-surface-variant);
    border-radius: 4px;
    padding: 0.75rem;
    margin: 0.75rem 0;
    display: none;
  }
  
  .context-message {
    margin: 0.5rem 0;
    padding: 0.5rem;
    border-radius: 4px;
    border: 1px solid var(--color-surface-variant);
    background-color: var(--color-surface-variant);
  }
  
  .context-message.current {
    border: 2px solid var(--color-accent);
    background-color: var(--color-surface);
  }
  
  .context-message-meta {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  
  .message-highlight {
    background-color: var(--color-accent) !important;
    color: var(--color-text-primary) !important;
    padding: 0.5rem 0.75rem !important;
    border-radius: 4px !important;
    transition: all 0.3s ease !important;
    border-left: 3px solid var(--color-text-primary) !important;
  }
  
  @media (max-width: 1024px) {
    .replay-container {
      flex-direction: column;
      gap: 1rem;
    }
    
    .replay-section .card {
      height: auto;
    }
    
    .messages-container,
    .suggestions-container {
      height: 400px;
    }
  }
  
  @media (max-width: 768px) {
    .button-group {
      flex-wrap: wrap;
    }
    
    .controls {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    
    .controls .form-group {
      width: 100%;
    }
    
    .controls .form-control {
      width: 100%;
    }
    
    .messages-container,
    .suggestions-container {
      height: 300px;
    }
  }
</style>

<%= javascript_tag do %>
  const messages = <%= raw @messages.to_json %>;
  const timePerMessage = <%= @time_per_message * 1000 %>; // Convert to milliseconds
  const incidentId = <%= @incident_id %>;
  let currentIndex = 0;
  let replayInterval;
  let subscription;
  let pollingInterval;
  let stats = { filtered: 0, enqueued: 0, received: 0 };
  let isReplayComplete = false;
  let autoScroll = true;

  function initializeWebSocket() {
    let consumer;
    if (typeof ActionCable !== 'undefined') {
      consumer = ActionCable.createConsumer();
    } else {
      console.error("ActionCable not available");
      return;
    }

    subscription = consumer.subscriptions.create(
      { channel: "IncidentSuggestionsChannel", incident_id: incidentId },
      {
        connected() {
          document.getElementById('queue-status').textContent = '(connected)';
          console.log('WebSocket connected successfully');
        },
        
        disconnected() {
          document.getElementById('queue-status').textContent = '(disconnected)';
          console.log('WebSocket disconnected');
        },
        
        received(data) {
          console.log('WebSocket received data:', data);
          console.log('Data type:', data.type);
          console.log('Current stats before processing:', { ...stats });
          
          if (data.type === 'job_completed') {
            console.log('Processing job_completed message');
            // Decrement enqueued counter since job is done
            const oldEnqueued = stats.enqueued;
            stats.enqueued = Math.max(0, stats.enqueued - 1);
            console.log(`Decremented enqueued from ${oldEnqueued} to ${stats.enqueued}`);
            
            if (data.suggestions && data.suggestions.length > 0) {
              console.log(`Job produced ${data.suggestions.length} suggestions`);
              stats.received++;
              displaySuggestions(data.suggestions);
            } else {
              console.log('Job completed with no suggestions');
            }
            
          } else if (data.type === 'job_failed') {
            console.log('Processing job_failed message');
            // Decrement enqueued counter even for failed jobs
            const oldEnqueued = stats.enqueued;
            stats.enqueued = Math.max(0, stats.enqueued - 1);
            console.log(`Decremented enqueued from ${oldEnqueued} to ${stats.enqueued} (failed job)`);
            console.error(`Job failed for message ${data.message_index}:`, data.error);
            
          } else if (data.suggestions) {
            console.log('Processing legacy suggestions message (no type field)');
            // Backward compatibility for old message format
            stats.received++;
            displaySuggestions(data.suggestions);
          } else {
            console.log('Received unknown message format:', data);
          }
          
          console.log('Current stats after processing:', { ...stats });
        },
        
        rejected() {
          document.getElementById('queue-status').textContent = '(rejected)';
        }
      }
    );
  }
  
  function startReplay() {
    const isStartingFresh = currentIndex === 0 || isReplayComplete;
    
    document.getElementById('start-replay').disabled = true;
    document.getElementById('start-replay').style.display = 'none';
    document.getElementById('stop-replay').style.display = 'inline-block';
    
    // Clear suggestions from database when starting fresh
    if (isStartingFresh) {
      document.getElementById('messages').innerHTML = '';
      document.getElementById('suggestions').innerHTML = '';
      currentIndex = 0;
      stats = { filtered: 0, enqueued: 0, received: 0 };
      isReplayComplete = false;
      
      // Clear suggestions from database when starting fresh
      fetch('/incidents/' + incidentId + '/clear_suggestions', { 
        method: 'POST',
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Content-Type': 'application/json'
        }
      });
    }
    
    initializeWebSocket();
    startPolling();
    
    // Enable auto-scroll during replay
    autoScroll = true;
    
    replayInterval = setInterval(function() {
      if (currentIndex < messages.length) {
        const message = messages[currentIndex];
        
        // Display the message
        const messageDiv = document.createElement('div');
        messageDiv.className = 'message-item';
        messageDiv.innerHTML = `<span class="message-speaker">${message.speaker}:</span> ${message.text}`;
        
        const messagesContainer = document.getElementById('messages');
        messagesContainer.appendChild(messageDiv);
        
        // Only auto-scroll if enabled and user hasn't scrolled up
        if (autoScroll) {
          const isScrolledToBottom = messagesContainer.scrollHeight - messagesContainer.clientHeight <= messagesContainer.scrollTop + 1;
          if (isScrolledToBottom) {
            messageDiv.scrollIntoView({ behavior: 'smooth' });
          }
        }
        
        // Send message for analysis (now async with filter)
        const startTime = performance.now();
        
        fetch('/incidents/' + incidentId + '/analyze_message', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            message: message,
            index: currentIndex
          })
        })
        .then(response => response.json())
        .then(data => {
          const responseTime = performance.now() - startTime;
          console.log(`Message ${currentIndex} - Status: ${data.status}, Filter: ${data.filter_time_ms}ms, Total: ${responseTime.toFixed(1)}ms`);
          
          if (data.status === 'filtered') {
            stats.filtered++;
          } else if (data.status === 'enqueued') {
            stats.enqueued++;
          }
        })
        .catch(error => console.error('Error analyzing message:', error));
        
        currentIndex++;
      } else {
        clearInterval(replayInterval);
        isReplayComplete = true;
        autoScroll = false;
        document.getElementById('start-replay').disabled = false;
        document.getElementById('start-replay').style.display = 'inline-block';
        document.getElementById('start-replay').textContent = 'Replay Again';
        document.getElementById('stop-replay').style.display = 'none';
        document.getElementById('reset-replay').style.display = 'none';
        
        // Keep WebSocket open for late-arriving suggestions
        setTimeout(() => {
          document.getElementById('queue-status').textContent = '(replay complete)';
        }, 2000);
      }
    }, timePerMessage);
  }
  
  function stopReplay() {
    if (replayInterval) {
      clearInterval(replayInterval);
      replayInterval = null;
    }
    
    if (subscription) {
      subscription.unsubscribe();
      subscription = null;
    }
    
    if (pollingInterval) {
      clearInterval(pollingInterval);
      pollingInterval = null;
    }
    
    // Disable auto-scroll when stopped
    autoScroll = false;
    
    document.getElementById('start-replay').disabled = false;
    document.getElementById('start-replay').style.display = 'inline-block';
    
    // Update button text and show reset button based on current state
    if (currentIndex === 0 || isReplayComplete) {
      document.getElementById('start-replay').textContent = 'Start Replay';
      document.getElementById('reset-replay').style.display = 'none';
    } else {
      document.getElementById('start-replay').textContent = `Continue Replay (from message ${currentIndex + 1})`;
      document.getElementById('reset-replay').style.display = 'inline-block';
    }
    
    document.getElementById('stop-replay').style.display = 'none';
    document.getElementById('queue-status').textContent = '(stopped)';
  }
  
  function resetReplay() {
    // Reset to beginning
    currentIndex = 0;
    isReplayComplete = false;
    autoScroll = true;
    document.getElementById('messages').innerHTML = '';
    document.getElementById('suggestions').innerHTML = '';
    stats = { filtered: 0, enqueued: 0, received: 0 };
    
    // Clear suggestions from database
    fetch('/incidents/' + incidentId + '/clear_suggestions', { 
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Content-Type': 'application/json'
      }
    });
    
    // Update button states
    document.getElementById('start-replay').textContent = 'Start Replay';
    document.getElementById('reset-replay').style.display = 'none';
  }
  
  function displaySuggestions(suggestions) {
    const suggestionsDiv = document.getElementById('suggestions');
    if (!suggestionsDiv) return;
    
    // Apply confidence filter
    const minConfidence = parseFloat(document.getElementById('confidence-filter').value);
    const filteredSuggestions = suggestions.filter(s => (s.confidence || 0.8) >= minConfidence);
    
    filteredSuggestions.forEach(suggestion => {
      const suggestionCard = document.createElement('div');
      suggestionCard.className = `suggestion-card ${suggestion.accepted ? 'accepted' : ''}`;
      
      const typeClasses = {
        'action_item': 'action-item',
        'trigger_event': 'trigger-event',
        'root_cause_theory': 'root-cause',
        'missing_metadata': 'missing-metadata'
      };
      
      const typeEmojis = {
        'action_item': '📝',
        'trigger_event': '🚨',
        'root_cause_theory': '🧠',
        'missing_metadata': '📊'
      };
      
      const typeLabels = {
        'action_item': 'Action Item',
        'trigger_event': 'Trigger Event',
        'root_cause_theory': 'Root Cause',
        'missing_metadata': 'Missing Metadata'
      };
      
      const confidence = suggestion.confidence ? ` (${Math.round(suggestion.confidence * 100)}%)` : '';
      const duplicateCount = suggestion.duplicate_count > 1 ? ` × ${suggestion.duplicate_count}` : '';
      const confidenceClass = suggestion.confidence > 0.8 ? 'status-success' : suggestion.confidence > 0.6 ? 'status-warning' : 'status-error';
      
      // Skip if suggestion already exists to prevent duplicates in UI
      if (document.getElementById(`suggestion-${suggestion.id}`)) {
        console.log(`Skipping duplicate suggestion ${suggestion.id} in UI`);
        return;
      }
      
      suggestionCard.innerHTML = `
        <div class="suggestion-header">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="suggestion-type ${typeClasses[suggestion.suggestion_type]}">
              ${typeEmojis[suggestion.suggestion_type]} ${typeLabels[suggestion.suggestion_type]}${duplicateCount}
            </span>
            <span class="${confidenceClass}" style="font-size: 0.75rem; font-weight: bold;">${confidence}</span>
            ${suggestion.duplicate_count > 1 ? '<span class="text-muted" style="font-size: 0.7rem;">(merged)</span>' : ''}
          </div>
          <span id="accepted-${suggestion.id}" class="status-success" style="display: ${suggestion.accepted ? 'inline' : 'none'};">✓ Accepted</span>
        </div>
        <div class="suggestion-content" onclick="jumpToMessage(${suggestion.source_transcript_index || suggestion.source_index})">
          ${suggestion.content}
        </div>
        <div id="context-${suggestion.id}" class="context-panel">
          <strong>Context:</strong><br/>
          <div id="context-messages-${suggestion.id}"></div>
        </div>
        <div class="suggestion-actions">
          <div class="suggestion-buttons">
            <button class="btn btn-secondary" onclick="showContext(${suggestion.id}, ${suggestion.source_transcript_index || suggestion.source_index}); event.stopPropagation();">Context</button>
            <button class="btn" onclick="acceptSuggestion(${suggestion.id}); event.stopPropagation();">Add to Record</button>
          </div>
          <div class="suggestion-meta">
            Message #${suggestion.source_transcript_index || suggestion.source_index || 'unknown'}
            ${suggestion.duplicate_count > 1 ? ` • ${suggestion.duplicate_count} similar` : ''}
          </div>
        </div>
      `;
      
      suggestionCard.id = `suggestion-${suggestion.id}`;
      suggestionsDiv.appendChild(suggestionCard);
      
      // Only auto-scroll suggestions if not many are present
      if (suggestionsDiv.children.length <= 3) {
        suggestionCard.scrollIntoView({ behavior: 'smooth' });
      }
    });
  }

  function startPolling() {
    pollingInterval = setInterval(() => {
      fetch(`/incidents/${incidentId}/suggestions`)
        .then(response => response.json())
        .then(data => {
          if (data.suggestions && data.suggestions.length > 0) {
            // Check for new suggestions
            const existingIds = Array.from(document.querySelectorAll('[id^="suggestion-"]'))
              .map(el => parseInt(el.id.replace('suggestion-', '')));
            
            const newSuggestions = data.suggestions.filter(s => !existingIds.includes(s.id));
            
            if (newSuggestions.length > 0) {
              console.log(`Displaying ${newSuggestions.length} new suggestions`);
              displaySuggestions(newSuggestions);
              
              // Update received count if we missed WebSocket messages
              const totalSuggestionsDisplayed = document.querySelectorAll('[id^="suggestion-"]').length;
              if (totalSuggestionsDisplayed > stats.received) {
                console.log(`Adjusting received count from ${stats.received} to ${totalSuggestionsDisplayed}`);
                stats.received = totalSuggestionsDisplayed;
              }
            }
            
            // Check for updated suggestions (merged content)
            data.suggestions.forEach(suggestion => {
              const existingCard = document.getElementById(`suggestion-${suggestion.id}`);
              if (existingCard) {
                const existingDuplicateCount = existingCard.querySelector('.suggestion-meta').textContent.includes('similar') ? 
                  parseInt(existingCard.querySelector('.suggestion-meta').textContent.match(/(\d+) similar/)?.[1] || '1') : 1;
                
                if (suggestion.duplicate_count > existingDuplicateCount) {
                  console.log(`Updating suggestion ${suggestion.id} with merged content`);
                  updateExistingSuggestion(suggestion);
                }
              }
            });
          }
          
          // Backup check: if replay is complete and we still have enqueued jobs, reset to 0
          if (isReplayComplete && stats.enqueued > 0) {
            console.log(`Replay complete but still showing ${stats.enqueued} enqueued jobs. Resetting to 0.`);
            stats.enqueued = 0;
          }
        })
        .catch(error => console.error('Polling error:', error));
    }, 3000);
  }
  
  function updateExistingSuggestion(suggestion) {
    const existingCard = document.getElementById(`suggestion-${suggestion.id}`);
    if (!existingCard) return;
    
    const typeClasses = {
      'action_item': 'action-item',
      'trigger_event': 'trigger-event',
      'root_cause_theory': 'root-cause',
      'missing_metadata': 'missing-metadata'
    };
    
    const typeEmojis = {
      'action_item': '📝',
      'trigger_event': '🚨',
      'root_cause_theory': '🧠',
      'missing_metadata': '📊'
    };
    
    const typeLabels = {
      'action_item': 'Action Item',
      'trigger_event': 'Trigger Event',
      'root_cause_theory': 'Root Cause',
      'missing_metadata': 'Missing Metadata'
    };
    
    const confidence = suggestion.confidence ? ` (${Math.round(suggestion.confidence * 100)}%)` : '';
    const duplicateCount = suggestion.duplicate_count > 1 ? ` × ${suggestion.duplicate_count}` : '';
    const confidenceClass = suggestion.confidence > 0.8 ? 'status-success' : suggestion.confidence > 0.6 ? 'status-warning' : 'status-error';
    
    existingCard.innerHTML = `
      <div class="suggestion-header">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <span class="suggestion-type ${typeClasses[suggestion.suggestion_type]}">
            ${typeEmojis[suggestion.suggestion_type]} ${typeLabels[suggestion.suggestion_type]}${duplicateCount}
          </span>
          <span class="${confidenceClass}" style="font-size: 0.75rem; font-weight: bold;">${confidence}</span>
          ${suggestion.duplicate_count > 1 ? '<span class="text-muted" style="font-size: 0.7rem;">(merged)</span>' : ''}
        </div>
        <span id="accepted-${suggestion.id}" class="status-success" style="display: ${suggestion.accepted ? 'inline' : 'none'};">✓ Accepted</span>
      </div>
      <div class="suggestion-content" onclick="jumpToMessage(${suggestion.source_transcript_index || suggestion.source_index})">
        ${suggestion.content}
      </div>
      <div id="context-${suggestion.id}" class="context-panel">
        <strong>Context:</strong><br/>
        <div id="context-messages-${suggestion.id}"></div>
      </div>
      <div class="suggestion-actions">
        <div class="suggestion-buttons">
          <button class="btn btn-secondary" onclick="showContext(${suggestion.id}, ${suggestion.source_transcript_index || suggestion.source_index}); event.stopPropagation();">Context</button>
          <button class="btn" onclick="acceptSuggestion(${suggestion.id}); event.stopPropagation();">Add to Record</button>
        </div>
        <div class="suggestion-meta">
          Message #${suggestion.source_transcript_index || suggestion.source_index || 'unknown'}
          ${suggestion.duplicate_count > 1 ? ` • ${suggestion.duplicate_count} similar` : ''}
        </div>
      </div>
    `;
    
    // Add a subtle animation to show the update
    existingCard.style.backgroundColor = 'var(--color-accent)';
    existingCard.style.transition = 'background-color 2s ease';
    
    setTimeout(() => {
      existingCard.style.backgroundColor = existingCard.classList.contains('accepted') ? 'var(--color-surface)' : 'var(--color-surface-variant)';
    }, 2000);
  }
  
  function acceptSuggestion(id) {
    fetch(`/suggestions/${id}/accept`, {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Content-Type': 'application/json'
      }
    })
    .then(response => response.json())
    .then(data => {
      const card = document.getElementById(`suggestion-${id}`);
      if (card) {
        card.classList.add('accepted');
        const acceptedSpan = document.getElementById(`accepted-${id}`);
        if (acceptedSpan) acceptedSpan.style.display = 'inline';
      }
    })
    .catch(error => console.error('Error accepting suggestion:', error));
  }
  
  function showContext(suggestionId, messageIndex) {
    const contextDiv = document.getElementById(`context-${suggestionId}`);
    const contextMessagesDiv = document.getElementById(`context-messages-${suggestionId}`);
    
    if (contextDiv.style.display === 'none' || !contextDiv.style.display) {
      // Show context - get 3 messages before the trigger, plus the trigger message
      const startIdx = Math.max(0, messageIndex - 3);
      const endIdx = messageIndex;
      
      // Check if we have any context to show
      if (startIdx >= messageIndex) {
        contextMessagesDiv.innerHTML = '<div class="text-muted" style="font-style: italic;">No previous messages available for context.</div>';
      } else {
        const contextMessages = messages.slice(startIdx, endIdx + 1);
        
        contextMessagesDiv.innerHTML = `
          <div class="text-muted" style="margin-bottom: 0.5rem; font-size: 0.7rem; font-style: italic;">
            Context shows the conversation leading up to this suggestion. The AI analyzed all these messages together.
          </div>
        ` + contextMessages.map((msg, idx) => {
          const actualIndex = startIdx + idx;
          const isCurrent = actualIndex === messageIndex;
          return `<div class="context-message ${isCurrent ? 'current' : ''}">
            <div class="context-message-meta">Message #${actualIndex} ${isCurrent ? '(Triggered this suggestion)' : ''}</div>
            <span class="message-speaker">${msg.speaker}:</span> ${msg.text}
          </div>`;
        }).join('');
      }
      
      contextDiv.style.display = 'block';
    } else {
      contextDiv.style.display = 'none';
    }
  }
  
  function jumpToMessage(messageIndex) {
    if (messageIndex === null || messageIndex === undefined) return;
    
    // Disable auto-scroll temporarily
    autoScroll = false;
    
    // Find the message div in the transcript
    const messagesDiv = document.getElementById('messages');
    const messageElements = messagesDiv.children;
    
    if (messageIndex < messageElements.length) {
      const targetMessage = messageElements[messageIndex];
      
      // Scroll to the message
      targetMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
      
      // Highlight it temporarily
      targetMessage.classList.add('message-highlight');
      
      // Remove highlight after 3 seconds
      setTimeout(() => {
        targetMessage.classList.remove('message-highlight');
      }, 3000);
    }
  }
  
  function dismissSuggestion(id) {
    updateSuggestionStatus(id, 'dismissed');
  }
  
  function updateSuggestionStatus(id, status) {
    fetch(`/suggestions/${id}/update_status`, {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ status: status })
    })
    .then(response => response.json())
    .then(data => {
      const card = document.getElementById(`suggestion-${id}`);
      if (card) {
        card.style.opacity = '0.5';
      }
    })
    .catch(error => console.error('Error updating suggestion:', error));
  }
  
  function exportAcceptedSuggestions() {
    fetch(`/incidents/${incidentId}/suggestions`)
      .then(response => response.json())
      .then(data => {
        const acceptedSuggestions = data.suggestions.filter(s => s.accepted);
        
        if (acceptedSuggestions.length === 0) {
          alert('No accepted suggestions to export');
          return;
        }
        
        // Create markdown content
        let content = '# Incident Report - Accepted Action Items\n\n';
        content += `Date: ${new Date().toLocaleDateString()}\n\n`;
        
        const byType = {};
        acceptedSuggestions.forEach(s => {
          if (!byType[s.suggestion_type]) byType[s.suggestion_type] = [];
          byType[s.suggestion_type].push(s);
        });
        
        const typeHeaders = {
          'action_item': '## 📝 Action Items',
          'trigger_event': '## 🚨 Trigger Events',
          'root_cause_theory': '## 🧠 Root Cause Analysis',
          'missing_metadata': '## 📊 Missing Metadata'
        };
        
        Object.keys(typeHeaders).forEach(type => {
          if (byType[type] && byType[type].length > 0) {
            content += `${typeHeaders[type]}\n\n`;
            byType[type].forEach(s => {
              content += `- ${s.content} (Message #${s.source_transcript_index || 'unknown'})\n`;
            });
            content += '\n';
          }
        });
        
        // Download file
        const blob = new Blob([content], { type: 'text/markdown' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `incident_report_${incidentId}_${new Date().getTime()}.md`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      })
      .catch(error => console.error('Error exporting suggestions:', error));
  }

  function filterSuggestions() {
    const minConfidence = parseFloat(document.getElementById('confidence-filter').value);
    const allCards = document.querySelectorAll('[id^="suggestion-"]');
    
    allCards.forEach(card => {
      const suggestionId = card.id.replace('suggestion-', '');
      // This is a simple implementation - in production you'd store suggestion data
      // For now, just show/hide based on confidence color
      const confidenceSpan = card.querySelector('.status-success, .status-warning, .status-error');
      if (confidenceSpan) {
        const confidenceText = confidenceSpan.textContent;
        const confidence = parseInt(confidenceText.replace(/[()%]/g, '')) / 100;
        
        if (confidence >= minConfidence) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      }
    });
  }

  // Detect user scrolling in messages container
  document.addEventListener('DOMContentLoaded', function() {
    const messagesContainer = document.getElementById('messages');
    let scrollTimeout;
    
    messagesContainer.addEventListener('scroll', function() {
      // Disable auto-scroll when user manually scrolls
      if (replayInterval) { // Only if replay is active
        autoScroll = false;
        
        // Clear previous timeout
        clearTimeout(scrollTimeout);
        
        // Re-enable auto-scroll after 3 seconds of no scrolling
        scrollTimeout = setTimeout(() => {
          const isScrolledToBottom = messagesContainer.scrollHeight - messagesContainer.clientHeight <= messagesContainer.scrollTop + 1;
          if (isScrolledToBottom) {
            autoScroll = true;
          }
        }, 3000);
      }
    });
  });

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    if (subscription) {
      subscription.unsubscribe();
    }
    if (pollingInterval) {
      clearInterval(pollingInterval);
    }
    if (replayInterval) {
      clearInterval(replayInterval);
    }
  });
<% end %> 